    <div class="top-bar">
        <h1>☀️ NYM <span>Ship Dock</span> — MDW7</h1>
        <div class="clock" id="clock"></div>
    </div>

    <div class="main">
        <!-- Left: QR + Instructions (always visible) -->
        <div class="left-panel">
            <div class="qr-wrapper">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&amp;data=https%3A%2F%2Fwenyeezy.github.io%2Fnym-shipdock%2F" alt="QR Code" width="220" height="220">
            </div>
            <div class="scan-label">📱 SCAN TO CHECK IN</div>
            <ul class="actions-list">
                <li><span class="emoji">📋</span><div><strong>Check In</strong><br><span class="desc">Start of shift — select your station</span></div></li>
                <li><span class="emoji">⏸️</span><div><strong>Temp Leave</strong><br><span class="desc">Temporarily stepping away from station</span></div></li>
                <li><span class="emoji">✏️</span><div><strong>Update</strong><br><span class="desc">Change your leave time</span></div></li>
                <li><span class="emoji">✅</span><div><strong>I'm Back</strong><br><span class="desc">Tap after you returned to station</span></div></li>
            </ul>
            <div class="url-label">wenyeezy.github.io/nym-shipdock</div>
        </div>

        <!-- Right: Tabbed Dashboard -->
        <div class="right-panel">
            <div class="tab-bar">
                <div class="tab-btn active" onclick="switchTab('overview')">📊 Station Overview</div>
                <div class="tab-btn" onclick="switchTab('log')">📋 Activity Log</div>
            </div>

            <!-- Tab 1: Station Overview -->
            <div id="tab-overview" class="tab-content active">
                <div class="dash-header">
                    <h2>Live Station Overview</h2>
                    <div class="refresh-info"><span class="refresh-dot"></span>Auto-refresh 30s</div>
                </div>
                <div class="stats-row">
                    <div class="stat-card blue"><div class="num" id="stat-checkin">-</div><div class="label">Checked In</div></div>
                    <div class="stat-card red"><div class="num" id="stat-leave">-</div><div class="label">Temp Leave</div></div>
                    <div class="stat-card yellow"><div class="num" id="stat-early">-</div><div class="label">Leaving Early</div></div>
                    <div class="stat-card green"><div class="num" id="stat-back">-</div><div class="label">Returned</div></div>
                </div>
                <div id="station-grid" class="station-grid"></div>
                <div class="empty-state" id="empty-overview" style="display:none;">No check-ins yet today. Waiting for associates...</div>
            </div>

            <!-- Tab 2: Activity Log -->
            <div id="tab-log" class="tab-content">
                <div class="dash-header">
                    <h2>Today's Activity Log</h2>
                    <div class="refresh-info"><span class="refresh-dot"></span>Auto-refresh 30s</div>
                </div>
                <table class="log-table">
                    <thead><tr><th>Time</th><th>Login</th><th>Action</th><th>Station</th><th>Detail</th></tr></thead>
                    <tbody id="log-body"></tbody>
                </table>
                <div class="empty-state" id="empty-log" style="display:none;">No activity yet today.</div>
            </div>
        </div>
    </div>

    <script>
        var BACKEND_URL = 'https://script.google.com/macros/s/AKfycbzcCeGW_qS6hkrd7Qvr7lBWw7QYpee7GcLbdp_HEiq-0C6nU37K05fOSZflxj_iiBdxfw/exec';

        // Tab switching
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(function(el) { el.classList.remove('active'); });
            document.querySelectorAll('.tab-btn').forEach(function(el) { el.classList.remove('active'); });
            document.getElementById('tab-' + tab).classList.add('active');
            var btns = document.querySelectorAll('.tab-btn');
            if (tab === 'overview') btns[0].classList.add('active');
            else btns[1].classList.add('active');
        }

        // Clock
        function updateClock() {
            var now = new Date();
            var h = now.getHours(); var ampm = h >= 12 ? 'PM' : 'AM';
            h = h % 12 || 12;
            var m = String(now.getMinutes()).padStart(2, '0');
            var s = String(now.getSeconds()).padStart(2, '0');
            try { document.getElementById('clock').textContent = h + ':' + m + ':' + s + ' ' + ampm; } catch(e) {}
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Load data
        function loadData() {
            try {
                fetch(BACKEND_URL + '?action=read', { redirect: 'follow' })
                    .then(function(r) { return r.json(); })
                    .then(function(data) { renderDashboard(data); })
                    .catch(function() {});
            } catch(e) {}
        }

        function renderDashboard(entries) {
            var today = new Date().toDateString();
            var todayEntries = entries.filter(function(e) {
                try { return new Date(e.Timestamp).toDateString() === today; } catch(x) { return false; }
            });

            // Stats
            var checkins = todayEntries.filter(function(e) { return e.Type === 'checkin'; });
            var leaves = todayEntries.filter(function(e) { return e.Type === 'temp_leave'; });
            var backs = todayEntries.filter(function(e) { return e.Type === 'im_back'; });
            var early = checkins.filter(function(e) { return e.Plan === 'early'; });

            document.getElementById('stat-checkin').textContent = checkins.length;
            document.getElementById('stat-leave').textContent = leaves.length;
            document.getElementById('stat-early').textContent = early.length;
            document.getElementById('stat-back').textContent = backs.length;

            // Station grid
            if (checkins.length === 0) {
                document.getElementById('empty-overview').style.display = 'block';
                document.getElementById('station-grid').innerHTML = '';
            } else {
                document.getElementById('empty-overview').style.display = 'none';
                var stations = {};
                checkins.forEach(function(e) {
                    var s = e.Station || 'Unknown';
                    if (!stations[s]) stations[s] = [];
                    stations[s].push(e.Login || '?');
                });
                var gridHtml = '';
                Object.keys(stations).sort().forEach(function(s) {
                    var people = stations[s].map(function(l) { return '<span class="login">' + l + '</span>'; }).join('');
                    gridHtml += '<div class="station-card"><div class="name">' + s + '</div><div class="people">' + people + '</div></div>';
                });
                document.getElementById('station-grid').innerHTML = gridHtml;
            }

            // Activity log (all today, most recent first)
            if (todayEntries.length === 0) {
                document.getElementById('empty-log').style.display = 'block';
                document.getElementById('log-body').innerHTML = '';
            } else {
                document.getElementById('empty-log').style.display = 'none';
                var sorted = todayEntries.slice().reverse();
                var logHtml = '';
                sorted.forEach(function(e) {
                    var time = '';
                    try {
                        var d = new Date(e.Timestamp);
                        var h = d.getHours() % 12 || 12;
                        time = h + ':' + String(d.getMinutes()).padStart(2, '0') + ' ' + (d.getHours() >= 12 ? 'PM' : 'AM');
                    } catch(x) { time = e.Timestamp || ''; }

                    var type = e.Type || '';
                    var badge = '<span class="badge ' + type + '">' + type.replace('_', ' ') + '</span>';
                    var detail = e.LeaveTime || e.Plan || '';

                    logHtml += '<tr><td>' + time + '</td><td>' + (e.Login || '') + '</td><td>' + badge + '</td><td>' + (e.Station || '-') + '</td><td>' + detail + '</td></tr>';
                });
                document.getElementById('log-body').innerHTML = logHtml;
            }
        }

        // Auto-refresh
        loadData();
        setInterval(loadData, 30000);
    </script>


</body></html>
