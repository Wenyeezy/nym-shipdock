    <title>NYM — Ship Dock | Live Display</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f172a;
            color: #f1f5f9;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top header bar */
        .top-bar {
            background: #1e293b;
            border-bottom: 2px solid #334155;
            padding: 12px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .top-bar h1 { font-size: 24px; font-weight: 800; color: #fff; }
        .top-bar h1 span { color: #ff9900; }
        .top-bar .clock { font-size: 20px; color: #94a3b8; font-family: 'SF Mono', Consolas, monospace; }

        /* Main layout */
        .main {
            flex: 1;
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 0;
            overflow: hidden;
        }

        /* Left panel */
        .left-panel {
            background: #1e293b;
            border-right: 2px solid #334155;
            padding: 28px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
        }
        .qr-wrapper {
            background: #ffffff;
            border-radius: 20px;
            padding: 18px;
            box-shadow: 0 0 40px rgba(59, 130, 246, 0.3);
            animation: pulse 3s ease-in-out infinite;
        }
        .qr-wrapper img { display: block; border-radius: 8px; }
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 30px rgba(59, 130, 246, 0.2); }
            50% { box-shadow: 0 0 60px rgba(59, 130, 246, 0.5); }
        }
        .scan-label { font-size: 18px; font-weight: 700; color: #60a5fa; text-align: center; }
        .actions-list { list-style: none; width: 100%; padding: 0 12px; }
        .actions-list li {
            margin-bottom: 12px; font-size: 16px; color: #cbd5e1; line-height: 1.5;
            display: flex; align-items: baseline; gap: 10px;
        }
        .actions-list li .emoji { font-size: 20px; flex-shrink: 0; }
        .actions-list li strong { color: #fff; font-size: 17px; }
        .actions-list li .desc { color: #94a3b8; font-size: 14px; }
        .url-label { font-size: 11px; color: #64748b; text-align: center; font-family: 'SF Mono', Consolas, monospace; }

        /* Right panel */
        .right-panel { padding: 24px 32px; overflow-y: auto; display: flex; flex-direction: column; }

        /* Tabs */
        .tab-bar { display: flex; gap: 4px; margin-bottom: 20px; }
        .tab-btn {
            padding: 10px 20px; border-radius: 8px; border: 1px solid #334155;
            background: #1e293b; color: #94a3b8; font-size: 14px; font-weight: 600;
            cursor: pointer; transition: all 0.15s;
        }
        .tab-btn.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
        .tab-btn:hover:not(.active) { background: #334155; }
        .tab-content { display: none; flex: 1; }
        .tab-content.active { display: block; }

        .dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .dash-header h2 { font-size: 18px; font-weight: 700; }
        .refresh-info { font-size: 13px; color: #64748b; }
        .refresh-dot {
            display: inline-block; width: 8px; height: 8px; border-radius: 50%;
            background: #22c55e; margin-right: 6px; animation: blink 2s infinite;
        }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        /* Stats row */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
        .stat-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 14px; text-align: center; }
        .stat-card .num { font-size: 34px; font-weight: 800; color: #fff; }
        .stat-card .label { font-size: 11px; color: #94a3b8; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
        .stat-card.blue .num { color: #60a5fa; }
        .stat-card.red .num { color: #f87171; }
        .stat-card.yellow .num { color: #fbbf24; }
        .stat-card.green .num { color: #4ade80; }

        /* Station grid */
        .station-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
        .station-card { background: #1e293b; border: 1px solid #334155; border-radius: 10px; padding: 12px; }
        .station-card .name { font-size: 12px; font-weight: 700; color: #94a3b8; text-transform: uppercase; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .station-card .people { font-size: 13px; color: #e2e8f0; }
        .station-card .people .login { display: inline-block; background: #334155; border-radius: 4px; padding: 2px 6px; margin: 2px; font-size: 12px; }

        /* Activity log table */
        .log-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .log-table th { text-align: left; padding: 10px 12px; background: #1e293b; color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #334155; position: sticky; top: 0; }
        .log-table td { padding: 9px 12px; border-bottom: 1px solid #1e293b; color: #e2e8f0; }
        .log-table tr:nth-child(even) td { background: #1e293b30; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .badge.checkin { background: #1e3a5f; color: #60a5fa; }
        .badge.temp_leave { background: #3b1111; color: #f87171; }
        .badge.update { background: #3b2f11; color: #fbbf24; }
        .badge.im_back { background: #11331a; color: #4ade80; }

        .empty-state { text-align: center; padding: 60px 20px; color: #64748b; font-size: 16px; }
    </style>
</head>
